# Copy to .env and fill in values for local development.

DEBUG=True
SECRET_KEY=local-dev-secret

# --- Local email (Gmail) ---
# Use a Google App Password: https://myaccount.google.com/apppasswords
# Leave RESEND_API_KEY empty so local mail uses SMTP, not Resend.
RESEND_API_KEY=

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=you@gmail.com
EMAIL_FROM_NAME=EzySchool

# Where signup-request admin alerts are delivered locally
ADMIN_NOTIFICATION_EMAIL=you@gmail.com
SUPPORT_EMAIL=you@gmail.com

# --- Stripe billing (test mode) ---
# See billing/STRIPE_SETUP.md for product/price lookup keys and webhook setup.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CHECKOUT_SUCCESS_URL=http://ldtc.localhost:3000/settings/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://ldtc.localhost:3000/settings/billing?checkout=cancel
STRIPE_PORTAL_RETURN_URL=http://ldtc.localhost:3000/settings/billing
