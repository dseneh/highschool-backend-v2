# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Option 1: Use DATABASE_URL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/highschool_v2

# Option 2: Use individual DB settings (for development)
DB_NAME=highschool_v2
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=prefer
DB_CONN_MAX_AGE=30

# JWT Settings
ACCESS_TOKEN_LIFETIME_MINUTES=5
REFRESH_TOKEN_LIFETIME_DAYS=1
JWT_SIGNING_KEY=your-jwt-secret-key-change-in-production

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=True

# ─────────────────────────────────────────────
# Email Provider Configuration
# Priority: RESEND_API_KEY -> EMAIL_BACKEND
# ─────────────────────────────────────────────
# Recommended default: SMTP backend (RESEND_API_KEY still takes priority)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Production (Option A): Resend REST API
# Get your API key at https://resend.com/
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Production (Option B): SMTP relay
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-smtp-username
# EMAIL_HOST_PASSWORD=your-smtp-password

# Sender identity shown in the "From" field
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM_NAME=EzySchool

# Frontend URL used when building password-reset links
FRONTEND_DOMAIN=http://localhost:3000
# True = use tenant subdomain link (e.g. tenant.localhost:3000/reset-password)
FRONTEND_USE_SUBDOMAIN=True
FRONTEND_DEV_MODE=True
FRONTEND_PASSWORD_RESET_PATH=/reset-password

# Optional: absolute logo URL shown in transactional emails
# Example: https://mail.ezyschool.net/logo/ezyschool-logo.png
EMAIL_LOGO_URL=

# How long (seconds) a password-reset token stays valid (default: 1 hour)
PASSWORD_RESET_TIMEOUT=3600
PASSWORD_RESET_REQUEST_COOLDOWN_SECONDS=60


# Storage Settings
USE_S3_STORAGE=False
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=auto
# AWS_S3_CUSTOM_DOMAIN=

# Language and Timezone
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
