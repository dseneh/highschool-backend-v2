# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Option 1: Use DATABASE_URL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/highschool_v2

# Option 2: Use individual DB settings (for development)
DB_NAME=highschool_v2
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSL_MODE=prefer
DB_CONN_MAX_AGE=30

# JWT Settings
ACCESS_TOKEN_LIFETIME_MINUTES=5
REFRESH_TOKEN_LIFETIME_DAYS=1
JWT_SIGNING_KEY=your-jwt-secret-key-change-in-production

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=True

# Storage Settings
USE_S3_STORAGE=False
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_REGION_NAME=auto
# AWS_S3_CUSTOM_DOMAIN=

# Language and Timezone
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
